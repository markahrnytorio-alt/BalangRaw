# LifeEase Frontend Environment Variables
#
# ─────────────────────────────────────────────────────────────────
# PRODUCTION
#   This file is the base env file. On Vercel, .env.local is NOT
#   deployed, so these production values are used automatically.
#   Locally, .env.local overrides these with localhost URLs.
# ─────────────────────────────────────────────────────────────────

# API URL - PHP Backend (production Hostinger)
NEXT_PUBLIC_API_URL=https://lifeease.site/backend/api
