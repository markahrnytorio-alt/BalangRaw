# LifeEase Frontend Environment Variables
#
# ---------------------------------------------------------------
# LOCAL DEVELOPMENT
#   This file overrides .env when running `next dev` locally.
#   It is NOT deployed to Vercel. Vercel uses .env (production)
#   or its own dashboard environment variables instead.
# ---------------------------------------------------------------

# API URL - PHP Backend (local XAMPP)
NEXT_PUBLIC_API_URL=http://localhost/LifeEase/backend/api
